{
  "name": "guestbook-appview",
  "version": "0.0.1",
  "description": "an appview for an atproto guestbook",
  "main": "dist/index.mjs",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env ./index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "dev:ingestor": "tsx watch --env-file=.env ./ingestor.ts",
    "dev:all": "npm run dev & npm run dev:ingestor",
    "start": "node --env-file=.env ./dist/index.mjs",
    "start:ingestor": "node --env-file=.env ./dist/ingestor.mjs",
    "keys:generate": "tsx --env-file=.env ./generate-keys.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "FujoCoded LLC",
  "license": "MIT",
  "dependencies": {
    "@atproto/api": "^0.14.19",
    "@atproto/identity": "^0.4.9",
    "@atproto/jwk-jose": "^0.1.11",
    "@atproto/lexicon": "^0.5.1",
    "@atproto/xrpc-server": "^0.9.5",
    "@libsql/client": "^0.15.4",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "body-parser": "^2.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.43.0",
    "express": "^5.1.0",
    "multiformats": "^13.4.1",
    "typescript": "^5.8.2",
    "ws": "^8.18.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.0",
    "tsdown": "^0.21.3",
    "tsx": "^4.19.3"
  }
}
